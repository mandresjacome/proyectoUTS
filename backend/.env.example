# Variables de entorno del backend
# Copiar este archivo como .env y completar los valores reales
# NUNCA subir el archivo .env al repositorio

# Puerto del servidor Express
PORT=3001

# Entorno de ejecución: development | production
NODE_ENV=development

# --- Google Cloud Document AI (Fase 3) ---
# GOOGLE_APPLICATION_CREDENTIALS=./credenciales/gcp-service-account.json
# DOCUMENT_AI_PROJECT_ID=tu-proyecto-gcp
# DOCUMENT_AI_LOCATION=us
# DOCUMENT_AI_PROCESSOR_ID=tu-processor-id

# --- Google Gemini API (Fase 4) ---
# GEMINI_API_KEY=tu-api-key-de-gemini
